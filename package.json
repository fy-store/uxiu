{
	"name": "uxiu-monorepo",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"scripts": {
		"dev": "pnpm dev:docs",
		"dev:core": "pnpm --filter uxiu run dev",
		"dev:docs": "pnpm --filter @uxiu/docs run dev",
		"build": "pnpm build:core && pnpm build:docs",
		"build:core": "pnpm --filter uxiu run build",
		"build:docs": "pnpm --filter @uxiu/docs run build",
		"preview": "pnpm --filter @uxiu/docs run preview",
		"test": "pnpm --filter ./packages/core run test",
		"test:run": "pnpm --filter ./packages/core run test:run",
		"test:cov": "pnpm --filter ./packages/core run test:cov",
		"test:dev": "pnpm --filter ./packages/core run test:dev",
		"typecheck": "pnpm -r --if-present run typecheck",
		"check": "pnpm typecheck && pnpm test:run && pnpm build"
	},
	"devDependencies": {
		"@types/koa": "^3.0.3",
		"@types/koa__router": "^12.0.5",
		"@types/lodash-es": "^4.17.12",
		"@types/node": "^25.9.3",
		"@vitest/coverage-v8": "4.1.8",
		"cross-env": "^10.1.0",
		"lodash-es": "^4.18.1",
		"tsdown": "^0.22.2",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
