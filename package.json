{
	"name": "uxiu",
	"type": "module",
	"version": "0.20.0-alpha.2",
	"description": "为 koa 后端应用提供基础模块的工具包",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		"./": "./dist/index.js",
		"./dependentUtils": "./dist/dependentUtils.js",
		"./utils": "./dist/utils.js",
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"module": "./dist/index.js",
	"files": [
		"dist",
		"*.d.ts"
	],
	"engines": {
		"node": "^18.0.0 || ^20.0.0 || >=22.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fy-store/uxiu.git"
	},
	"keywords": [
		"uxiu",
		"uxiu-cli",
		"koa"
	],
	"author": "feiYu <feiyucode@gmail.com>",
	"license": "MIT",
	"scripts": {
		"test": "vitest",
		"test:cov": "vitest run --coverage",
		"dev": "cross-env NODE_ENV=development tsx watch ./src/index.ts",
		"test:dev": "cross-env NODE_ENV=development port=3323 tsx watch ./tests/dev/index.ts",
		"build": "tsdown",
		"priview": "pnpm run build && pnpm run pro"
	},
	"devDependencies": {
		"@types/koa": "^2.15.0",
		"@types/koa__router": "^12.0.5",
		"@types/lodash-es": "^4.17.12",
		"@types/node": "^20.16.6",
		"@vitest/coverage-v8": "2.1.8",
		"cross-env": "^7.0.3",
		"lodash-es": "^4.17.21",
		"tsdown": "^0.12.9",
		"tsx": "^4.19.0",
		"typescript": "^5.5.4",
		"vitest": "^2.0.5"
	},
	"peerDependencies": {
		"@koa/router": "^14.0.0",
		"koa": "^2.15.3",
		"log4js": "^6.9.1",
		"path-to-regexp": "^8.2.0"
	},
	"dependencies": {
		"@oxc-project/runtime": "^0.87.0",
		"event-imt": "^0.1.0"
	},
	"volta": {
		"node": "20.17.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}