{
	"name": "uxiu",
	"type": "module",
	"version": "0.21.0",
	"description": "为 koa 后端应用提供基础模块的工具包",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./dist/index.mjs",
		"./dependence": "./dist/dependence.mjs",
		"./node": "./dist/node.mjs",
		"./utils": "./dist/utils.mjs",
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"files": [
		"dist",
		"*.d.ts"
	],
	"engines": {
		"node": ">=22.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fy-store/uxiu.git"
	},
	"keywords": [
		"uxiu",
		"uxiu-cli",
		"koa"
	],
	"author": "feiYu <feiyucode@gmail.com>",
	"license": "MIT",
	"scripts": {
		"test": "vitest",
		"test:cov": "vitest run --coverage",
		"dev": "cross-env NODE_ENV=development tsx watch ./src/index.ts",
		"test:dev": "cross-env NODE_ENV=development port=3323 tsx watch ./tests/dev/index.ts",
		"build": "tsdown",
		"priview": "pnpm run build && pnpm run pro"
	},
	"devDependencies": {
		"@types/koa": "^3.0.3",
		"@types/koa__router": "^12.0.5",
		"@types/lodash-es": "^4.17.12",
		"@types/node": "^25.9.3",
		"@vitest/coverage-v8": "4.1.8",
		"cross-env": "^10.1.0",
		"lodash-es": "^4.18.1",
		"tsdown": "^0.22.2",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"peerDependencies": {
		"@koa/router": "^15.0.0",
		"koa": "^3.0.0",
		"log4js": "^6.0.0",
		"path-to-regexp": "^8.0.0"
	},
	"peerDependenciesMeta": {
		"@koa/router": {
			"optional": true
		},
		"koa": {
			"optional": true
		},
		"log4js": {
			"optional": true
		},
		"path-to-regexp": {
			"optional": true
		}
	},
	"dependencies": {
		"@oxc-project/runtime": "^0.135.0",
		"event-imt": "^0.2.7"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}